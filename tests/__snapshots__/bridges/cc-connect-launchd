<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wp.cc-connect</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/cc-connect</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/var/www/site</string>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/home/chubes/.cc-connect/cc-connect.log</string>
    <key>StandardErrorPath</key>
    <string>/home/chubes/.cc-connect/cc-connect.error.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
